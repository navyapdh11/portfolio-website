# Auth secrets — REQUIRED for server to start
# Generate these with:
#   ADMIN_SECRET: node -e "require('crypto').randomBytes(32).toString('hex')"
#   SESSION_SIGNING_KEY: node -e "require('crypto').randomBytes(64).toString('hex')"
ADMIN_SECRET=
SESSION_SIGNING_KEY=

# Trusted origins for CSRF validation (defaults to localhost in dev)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
